{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "frontend/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "backend",
    "runtime": "nodejs20",
    "environmentVariables": {
      "FIREBASE_PROJECT_ID": "twitter-clone-927ae",
      "ALGOLIA_INDEX_NAME": "posts",
      "FRONTEND_URL": "https://twitter-clone-927ae.web.app"
    }
  }
}
